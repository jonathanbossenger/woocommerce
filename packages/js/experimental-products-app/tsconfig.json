{
	"extends": "../internal-ts-config/tsconfig.json",
	"compilerOptions": {
		"rootDir": "src",
		"noCheck": false,
		"outDir": "build-module",
		"declaration": true,
		"declarationMap": true,
		"declarationDir": "./build-types",
		"resolveJsonModule": true,
		"jsx": "react-jsx",
		"jsxFactory": null,
		"jsxFragmentFactory": null
	},
	"include": [ "src/**/*" ],
	"exclude": [
		"**/test/**",
		"**/stories/**",
		"**/*.test.ts",
		"**/*.test.tsx"
	]
}
